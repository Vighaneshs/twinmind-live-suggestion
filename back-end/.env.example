TAVILY_API_KEY=
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Optional: comma-separated extra domains to APPEND to the built-in
# clickbait/SEO deny list (e.g. forum or aggregator sites you don't trust).
TAVILY_EXCLUDE_DOMAINS=

# Optional: comma-separated extra domains to APPEND to the built-in
# allow list (boosts ranking but does NOT restrict search).
TAVILY_INCLUDE_DOMAINS=

# Optional: STRICT include — comma-separated domains. If set, Tavily ONLY
# searches these. Use sparingly; can starve the LLM of context.
TAVILY_STRICT_INCLUDE_DOMAINS=
